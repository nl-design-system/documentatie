---
import { Card } from '@components/card/card';
import { UnorderedList } from '@components/unordered-list/unordered-list';
const { title, sc, status } = Astro.props;
---

<UnorderedList.Item>
  <Card heading={title}>
    <dl>
      <dt>sc:</dt>
      <dd>{sc}</dd>
      <dt>status:</dt>
      <dd>{status}</dd>
    </dl>

    <slot />
  </Card>
</UnorderedList.Item>
