---
const { testCategory } = Astro.props;
import '@utrecht/accordion-css/dist/index.css';
import '@nl-design-system-candidate/button-css/button.css';
import { IconChevronDown } from '@tabler/icons-react';
import { UnorderedList } from '@amsterdam/design-system-react';
---

<div class="utrecht-accordion">
  <details class="utrecht-accordion__section">
    <summary class="utrecht-accordion__header">
      <span class="nl-button nl-button--subtle">
        <span class="nl-button__icon-start">
          <IconChevronDown />
        </span>
        <span class="nl-button__label">
          {testCategory}
        </span>
      </span>
    </summary>

    <div class="utrecht-accordion__panel">
      <UnorderedList markers={false}>
        <slot />
      </UnorderedList>
    </div>
  </details>
</div>

<style>
  .utrecht-accordion__section .nl-button__icon-start {
    transition: rotate 0.4s ease-in-out;
  }

  .utrecht-accordion__section[open] .nl-button__icon-start {
    rotate: 180deg;
  }

  .utrecht-accordion__header {
    display: flex;

    .nl-button {
      flex: 1;
      justify-content: start;
      --nl-button-border-radius: 0;
    }
  }
</style>
