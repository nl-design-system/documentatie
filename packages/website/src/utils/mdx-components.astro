---
import { OverviewPage } from '@components/overview-page/overview-page.tsx';
import { DocCardList } from '@components/doc-card-list/doc-card-list';
import ComponentOverview from '@components/docusaurus-mocks/ComponentOverview.astro';
import ComponentAnatomy from '@components/docusaurus-mocks/ComponentAnatomy.astro';
import CriteriaList from '@components/docusaurus-mocks/CriteriaList.astro';
import CriteriaListItem from '@components/docusaurus-mocks/CriteriaListItem.astro';
import { Checklist, ChecklistItem } from '@site/src/components/Checklist';
import { Heading1, Heading2, Heading3, Heading4, Heading5, Heading6 } from '@components/heading/heading';
import { UnorderedList } from '@components/unordered-list/unordered-list';
import { Paragraph } from '@components/paragraph/paragraph';
import { Link } from '@components/link/link';
import { Image } from '@components/img/img';

export const MDXComponents = async ({ navigationItems } = {}) => {
  return {
    Checklist,
    ChecklistItem,
    ComponentOverview,
    ComponentAnatomy,
    CriteriaList,
    CriteriaListItem,
    OverviewPage: (props) => OverviewPage({ ...props, pages: navigationItems || [] }),
    DocCardList,
    h1: Heading1,
    h2: Heading2,
    h3: Heading3,
    h4: Heading4,
    h5: Heading5,
    h6: Heading6,
    ul: UnorderedList,
    li: UnorderedList.Item,
    p: Paragraph,
    a: Link,
    img: (props) => Image({ width: '100%', ...props }),
  };
};
---
