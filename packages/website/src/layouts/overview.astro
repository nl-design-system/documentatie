---
import Document, { type Props as DocumentProps } from './document.astro';
import { BreadcrumbNav, BreadcrumbNavLink, BreadcrumbNavSeparator } from '@components/breadcrumb-nav/breadcrumb-nav';
import { IconChevronRight } from '@tabler/icons-react';
import { SideNavigation } from '@components/side-navigation/side-navigation.tsx';
import { navigation } from '../navigation.config.ts';
import { getBreadcrumbsForElement } from '../navigation/get-breadcrumbs-for-element.ts';
import './overview.css';
import { withCurrentIndication } from 'src/navigation/with-current-indication';
import { serialiseNavigationTree } from 'src/navigation/serialise-navigation-tree';

export type Props = DocumentProps;

const { navigationTree, navigationList } = await withCurrentIndication(navigation, Astro.url.pathname);
const breadcrumbPath = await getBreadcrumbsForElement(navigationList, Astro.url.pathname);
const treeLevelOne = navigationTree.items.find((item) => item.expanded || item.current);
const items = serialiseNavigationTree(treeLevelOne);
const { ...props } = Astro.props;
---

<Document {...props}>
  <div class="ma-layout-overview">
    <div class="ma-layout-overview__content">
      <div class="ma-layout-overview__side-bar">
        <SideNavigation items={[items.items || []]} client:load />
      </div>

      {
        breadcrumbPath.length > 0 && (
          <nav class="ma-layout-overview__breadcrumb-nav" aria-labelledby="breadcrumb-label">
            <h2 hidden id="breadcrumb-label">
              Kruimelpad
            </h2>
            <BreadcrumbNav>
              {breadcrumbPath.map((item, index, list) => (
                <>
                  <BreadcrumbNavLink href={item.href || ''} disabled={!item.href}>
                    {item.label}
                  </BreadcrumbNavLink>
                  {index < list.length - 1 ? (
                    <BreadcrumbNavSeparator>
                      <IconChevronRight />
                    </BreadcrumbNavSeparator>
                  ) : null}
                </>
              ))}
            </BreadcrumbNav>
          </nav>
        )
      }

      <main id="main" class="ma-layout-overview__main">
        <div class="ma-layout-overview__main-body">
          <slot />
        </div>
      </main>
    </div>
  </div>
</Document>
