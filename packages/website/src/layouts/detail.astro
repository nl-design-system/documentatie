---
import Document, { type Props as DocumentProps } from './document.astro';
import { BreadcrumbNav, BreadcrumbNavLink, BreadcrumbNavSeparator } from '@components/breadcrumb-nav/breadcrumb-nav';
import { IconChevronRight } from '@tabler/icons-react';
import TableOfContents from '@components/table-of-content/table-of-content.astro';
import { SideNavigation } from '@components/side-navigation/side-navigation.tsx';
import { navigation } from '../navigation.config.ts';
import { getBreadcrumbsForElement } from '../navigation/get-breadcrumbs-for-element.ts';
import { withCurrentIndication } from 'src/navigation/with-current-indication.ts';
import { serialiseNavigationTree } from 'src/navigation/serialise-navigation-tree.ts';
import './detail.css';

export type Props = DocumentProps;

const { navigationTree, navigationList } = await withCurrentIndication(navigation, Astro.url.pathname);
const breadcrumbPath = getBreadcrumbsForElement(navigationList, Astro.url.pathname);
const treeLevelOne = navigationTree.items.find((item) => item.expanded || item.current);
const items = serialiseNavigationTree(treeLevelOne);
const { ...props } = Astro.props;
---

<Document {...props}>
  <div class="ma-layout-detail">
    <div class="ma-layout-detail__content">
      <div class="ma-layout-detail__side-nav">
        <SideNavigation aria-labelledby="side-navigation-label" items={[items.items || []]} client:load />
      </div>

      {
        breadcrumbPath.length > 0 && (
          <nav class="ma-layout-detail__breadcrumb-nav" aria-labelledby="breadcrumb-label">
            <h2 hidden id="breadcrumb-label">
              Kruimelpad
            </h2>
            <BreadcrumbNav>
              {breadcrumbPath.map((item, index, list) => (
                <>
                  <BreadcrumbNavLink index={index} href={item.href || ''} disabled={!item.href}>
                    {item.label}
                  </BreadcrumbNavLink>
                  {index < list.length - 1 ? (
                    <BreadcrumbNavSeparator>
                      <IconChevronRight />
                    </BreadcrumbNavSeparator>
                  ) : null}
                </>
              ))}
            </BreadcrumbNav>
          </nav>
        )
      }

      <main id="main" class="ma-layout-detail__main ma-flow" lang={props.lang === 'en' ? 'en' : null}>
        <header class="ma-layout-detail__header"><slot name="header" /></header>

        <aside class="ma-layout-detail__anchor-nav">
          <TableOfContents />
        </aside>

        <div class="ma-layout-detail__main-body ma-flow ma-body-copy">
          <slot />
        </div>
      </main>
    </div>
  </div>
</Document>
