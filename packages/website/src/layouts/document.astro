---
import { siteName, siteTitle, siteThemeColor, siteColorScheme, siteKeywords, twitterCard } from '../seo.config.ts';
import { PageHeader } from '@components/page-header/page-header';
import { PageFooter } from '@components/page-footer/page-footer';
import { NavBar } from '@components/nav-bar/nav-bar';
import { PageLayout } from '@components/page-layout/page-layout';
import { SkipLink } from '@components/skip-link/skip-link.tsx';
import { NavList } from '@components/nav-list/nav-list';
import { NavListLink } from '@components/nav-list/nav-list';
import { Logo } from '@components/logo/logo';
import { LinkList, LinkListLink } from '@components/link-list/link-list';
import { MobileMenu, MobileMenuTrigger } from '@components/mobile-menu/mobile-menu';
import { IconChevronRight } from '@tabler/icons-react';
import { SideNavigation } from '@components/side-navigation/side-navigation.tsx';
import { getMainNavigation } from '../navigation';
import { navigation } from '../navigation.config.ts';

import '@fontsource/fira-code';
import '@fontsource/fira-sans/700';
import '@fontsource/source-sans-pro';
import '@fontsource/source-sans-pro/700.css';
import '@utrecht/root-css/dist/index.css';
import '@components/flow/flow.css';

// NLDS markdown components
import '@utrecht/button-css/dist/index.css';
import '@utrecht/blockquote-css/dist/index.css';
import '@utrecht/custom-checkbox-css/dist/index.css';
import '@utrecht/checkbox-css/dist/index.css';
import '@utrecht/emphasis-css/dist/index.css';
import '@utrecht/figure-css/dist/index.css';
import '@utrecht/form-label-css/dist/index.css';
import '@utrecht/form-field-css/dist/index.css';
import '@utrecht/form-fieldset-css/dist/index.css';
import '@utrecht/form-field-description-css/dist/index.css';
import '@utrecht/separator-css/dist/index.css';
import '@utrecht/ordered-list-css/dist/index.css';
import '@utrecht/table-css/dist/index.css';
import '@utrecht/textarea-css/dist/index.css';
import '@utrecht/textbox-css/dist/index.css';
import '@utrecht/img-css/dist/index.css';
import '@utrecht/spotlight-section-css/dist/index.css';
import '@nl-design-system-candidate/paragraph-css/paragraph.css';
import '@nl-design-system-candidate/code-css/code.css';
import '@nl-design-system-candidate/code-block-css/code-block.css';

import 'a11y-syntax-highlighting/dist/prism/a11y-dark.css';
import '../../src/styles/missing-tokens.css';
import './document.css';
import { serialiseNavigationTree } from 'src/navigation/serialise-navigation-tree';
import { withCurrentIndication } from 'src/navigation/with-current-indication.ts';
import '@components/sr-only/sr-only.css';
import '@components/body-copy/body-copy.css';

export interface Props {
  title: string;
  titleSm?: string;
  description?: string;
  lang?: 'nl' | 'en';
  seoImage?: string;
  seoImageAlt?: string;
  keywords?: string[];
  index?: boolean;
  follow?: boolean;
}

const { title, titleSm, description, lang = 'nl', keywords, seoImage, seoImageAlt, index = true, follow } = Astro.props;

const fallbackSeoImage = '/social-image_nl-design-system.png';
const fallbackSeoImageAlt = 'Logo van NL Design System';

const documentTitle = `${titleSm || title} · ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://nldesignsystem.nl');
const _seoImage = new URL(seoImage || fallbackSeoImage, Astro.url.origin);
const _seoImageAlt = seoImage ? seoImageAlt : fallbackSeoImageAlt;
const _keywords = new Set([...siteKeywords, ...(keywords || [])]);
const _follow = follow === undefined ? index : follow;
const _robots = `${index ? 'index' : 'noindex'} ${_follow ? 'follow' : 'nofollow'}`;

const { navigationTree } = await withCurrentIndication(navigation, Astro.url.pathname);
const items = serialiseNavigationTree(navigationTree);
const mainNavigationItems = await getMainNavigation(navigation, Astro.url.pathname);

const footerNavigationItems = [
  { href: '/blog/', label: 'Blog' },
  { href: '/project/kernteam/', label: 'Contact' },
  { href: '/toegankelijkheidsverklaring/', label: 'Toegankelijkheid' },
  { href: '/privacyverklaring/', label: 'Privacyverklaring' },
  { href: '/colofon/', label: 'Colofon' },
  { href: '/github/', label: 'GitHub' },
  { href: '/slack/', label: 'Slack' },
  { href: '/figma/', label: 'Figma' },
  { href: 'https://www.linkedin.com/company/nl-design-system/', label: 'LinkedIn', external: true },
];
---

<html class="utrecht-root" lang={lang} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{documentTitle}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="theme-color" content={siteThemeColor} />
    <meta name="color-scheme" content={siteColorScheme} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={description} />
    <meta name="keywords" content={[..._keywords].join(', ')} />
    <meta name="robots" content={_robots} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={_seoImage} />
    <meta property="og:image:alt" content={_seoImageAlt} />
    <meta property="og:description" content={description} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={lang} />
    <meta property="twitter:card" content={twitterCard} />

    <slot name="head" />
  </head>

  <body>
    <SkipLink href="#main">Naar de inhoud</SkipLink>
    <PageLayout>
      <PageHeader>
        <MobileMenuTrigger />
        <a href="/" aria-label="Link naar Homepagina"><Logo /></a>
      </PageHeader>
      <NavBar>
        <nav aria-labelledby="hoofdnavigatie-label">
          <h2 hidden id="hoofdnavigatie-label">Hoofdmenu</h2>
          <NavList>
            {
              mainNavigationItems.map(({ href, label, expanded, current }) => (
                <NavListLink href={href} aria-current={expanded || current ? 'page' : null}>
                  {label}
                </NavListLink>
              ))
            }
          </NavList>
        </nav>
      </NavBar>

      <slot />

      <PageFooter>
        <nav aria-labelledby="site-navigatie-label">
          <h2 hidden id="site-navigatie-label">Submenu</h2>
          <LinkList>
            {
              footerNavigationItems.map(({ href, label }) => (
                <LinkListLink href={href}>
                  {label}
                  <span class="utrecht-icon" slot="icon">
                    <IconChevronRight />
                  </span>
                </LinkListLink>
              ))
            }
          </LinkList>
        </nav>
      </PageFooter>
    </PageLayout>

    <MobileMenu>
      <SideNavigation items={[items.items]} client:load />
    </MobileMenu>

    <script>
      import 'invokers-polyfill';
    </script>
  </body>
</html>

<style is:global>
  /* These styles are temporary to let axe pass. When actual components are
  being implemented, these styles will be removed */
  a,
  input,
  summary {
    display: inline-block;
    min-height: 24px;
  }
</style>
