---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import Document from '@layouts/document.astro';
import { MDXComponents } from '@utils/mdx-components.astro';
import { siteTitle } from '../seo.config.ts';

export async function getStaticPaths() {
  const components = await getCollection('components');

  return components
    .filter((page) => page.data?.unlisted !== true)
    .map((page) => ({
      params: { component: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await render(page);

const title = page.data.title ? `${page.data.title} | ${siteTitle}` : siteTitle;
const description =
  page.data.title && page.data.description ? `${page.data.title}: ${page.data.description}` : page.data.description;
---

<Document
  title={title}
  description={description}
  lang={page.data.lang}
  seoImage={page.data.image}
  seoImageAlt={page.data.image_alt}
  keywords={['component', page.data.title?.toLowerCase() || '', ...(page.data.keywords || [])]}
  index={page.data.unlisted !== true}
>
  <Content components={MDXComponents} />
</Document>
