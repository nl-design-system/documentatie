---
import { getCollection } from 'astro:content';
import OverviewLayout from '@layouts/overview.astro';
import { isNavigationGroup, isNavigationItem } from '../navigation';
import { getNavigationElement } from '../navigation/get-navigation-element.ts';
import { OverviewPage } from '@components/overview-page/overview-page';
import { navigation } from 'src/navigation.config';
import { Grid } from '@components/grid/grid';

export async function getStaticPaths() {
  const pages = await getCollection('overviewPages');

  return pages.map((page) => ({
    params: { overview: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { navigationList } = (await navigation)();
const navigationElement = getNavigationElement(navigationList, Astro.url.pathname);

let pages = isNavigationGroup(navigationElement) && navigationElement.items ? navigationElement.items : [];
pages = isNavigationItem(navigationElement) ? navigationElement.parent?.items || pages : pages;

pages = await Promise.all(pages);
---

<OverviewLayout
  title={page.data.title}
  titleSm={page.data.title_sm}
  description={page.data.description}
  lang={page.data.lang}
  seoImage={page.data.image}
  seoImageAlt={page.data.image_alt}
  keywords={page.data.keywords}
  index={page.data.unlisted !== true}
>
  <Grid>
    <Grid.Cell span="all">
      <h1>{page?.data?.title}</h1>
      <p>{page?.data?.description}</p>
    </Grid.Cell>
  </Grid>

  <OverviewPage pages={pages} />
</OverviewLayout>
