---
import { getCollection } from 'astro:content';
import { siteDescription, siteTitle } from '../seo.config.ts';
import CenterColumnLayout from '@layouts/center-column.astro';
import { Grid } from '@components/grid/grid';

const docs = await getCollection('docs');
const wcag = await getCollection('wcag');
const components = await getCollection('components');

const sections: Record<string, { title: string; titleSm?: string; id: string }[]> = {};

type DocsArray = typeof docs;

const getDuplicateTitles = (docs: DocsArray) => {
  type CountMap = { [index: string]: any[] };
  const titles: CountMap = {};
  docs.reduce((map, doc) => {
    const title = doc.data.title ?? '';
    if (Object.hasOwn(map, title)) {
      map[title].push(doc);
    } else {
      map[title] = [doc];
    }
    return map;
  }, titles);

  return Object.values(titles).filter((x) => x.length > 1);
};

[...components, ...docs, ...wcag].forEach((doc) => {
  if (!doc.filePath) return;
  const relativeFilePath = doc.filePath.replace('../../docs/', '');
  const section = relativeFilePath.split('/').at(0) || '';
  if (!sections[section]) {
    sections[section] = [];
  }
  sections[section].push({ title: doc.data.title, titleSm: doc.data.title_sm, id: doc.id });
});

const duplicates = getDuplicateTitles(docs);
const placeholderTitle = '(geen paginatitel)';
---

<CenterColumnLayout title={siteTitle} description={siteDescription} showBreadcrumbs={false}>
  <Grid>
    <Grid.Cell span="all">
      <h1>NL Design System gerenderd met Astro</h1>
    </Grid.Cell>
  </Grid>
  <Grid className="section">
    <Grid.Cell span="all">
      <p>Section</p>
    </Grid.Cell>
  </Grid>

  <Grid>
    <Grid.Cell span={6}>
      <div class="blokje">Blokje</div>
    </Grid.Cell>

    <Grid.Cell span={6}>
      <div class="blokje">Blokje</div>
    </Grid.Cell>
  </Grid>

  <Grid>
    <Grid.Cell span="all">
      {
        duplicates.length > 1 ? (
          <aside>
            <h2>Waarschuwing: paginatitels moeten uniek zijn</h2>
            <p>
              Er zijn paginatitels die voor meerdere pagina's worden gebruikt. Pas de paginatitels aan zodat ze uniek
              zijn binnen deze website.
            </p>
            <ul>
              {duplicates.map((group) => (
                <li>
                  {group[0].data.title ?? placeholderTitle}
                  <ul>
                    {group.map((doc) => (
                      <li>
                        <a href={doc.id}>{doc.data.title ?? placeholderTitle}</a>
                      </li>
                    ))}
                  </ul>
                </li>
              ))}
            </ul>
          </aside>
        ) : null
      }
    </Grid.Cell>
  </Grid>
</CenterColumnLayout>

<style is:global>
  .section {
    position: relative;
    z-index: 0;
  }
  .section::before {
    content: '';
    display: block;
    position: absolute;
    inline-size: 200vw;
    block-size: 100%;
    left: 50%;
    translate: -50%;
    background-color: hotpink;
    z-index: -1;
  }
  .blokje {
    background-color: rebeccapurple;
    color: white;
  }
</style>
