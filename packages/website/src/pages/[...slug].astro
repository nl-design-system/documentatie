---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import Document from '@layouts/document.astro';
import OverviewPage from '@components/docusaurus-mocks/OverviewPage.astro';
import DocCardList from '@components/docusaurus-mocks/DocCardList.astro';
import ComponentOverview from '@components/docusaurus-mocks/ComponentOverview.astro';
import ComponentAnatomy from '@components/docusaurus-mocks/ComponentAnatomy.astro';
import CriteriaList from '@components/docusaurus-mocks/CriteriaList.astro';
import CriteriaListItem from '@components/docusaurus-mocks/CriteriaListItem.astro';
import { Checklist, ChecklistItem } from '@site/src/components/Checklist';
import { siteTitle } from '../seo.config.ts';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const components = await getCollection('components');

  return [...docs, ...components]
    .filter((page) => page.data?.unlisted !== true)
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---

<Document
  title={page.data.title ? `${page.data.title} | ${siteTitle}` : siteTitle}
  description={page.data.description}
  lang={page.data.lang}
  seoImage={page.data.image}
  seoImageAlt={page.data.image_alt}
  keywords={page.data.keywords}
  index={page.data.unlisted !== true}
>
  <Content
    components={{
      Checklist,
      ChecklistItem,
      ComponentOverview,
      ComponentAnatomy,
      CriteriaList,
      CriteriaListItem,
      OverviewPage,
      DocCardList,
    }}
  />
</Document>
